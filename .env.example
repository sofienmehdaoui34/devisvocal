# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Claude (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI Whisper ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Telegram Bot ───────────────────────────────────────────
# Obtenir via @BotFather sur Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Secret renvoyé par Telegram dans X-Telegram-Bot-Api-Secret-Token (auth webhook).
# Passé automatiquement à setWebhook. Laisser vide en dev pour désactiver la vérif.
TELEGRAM_WEBHOOK_SECRET=

# ─── Twilio (WhatsApp) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN sert aussi à valider la signature X-Twilio-Signature
# des webhooks entrants. Laisser vide en dev pour désactiver la vérif.
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886
# (Historique) ancien token de vérif 360dialog — non utilisé avec Twilio.
WHATSAPP_WEBHOOK_SECRET=
# URL publique de l'API (derrière le proxy Railway) pour reconstruire l'URL
# exacte vue par Twilio lors de la validation de signature. Ex: https://api.devisvocal.ch
WEBHOOK_BASE_URL=

# ─── Google Maps (recherche entreprise onboarding) ───────────
GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── INSEE Sirene (SIRET lookup, France) ────────────────────
# Clé gratuite sur api.insee.fr — optionnel pour la Suisse
INSEE_API_TOKEN=

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_DEVIS=2.90
# Nombre de devis offerts par artisan avant le passage au paiement (défaut 3).
FREE_DEVIS_LIMIT=3

# ─── Resend (email) ─────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=devis@devisvocal.ch
EMAIL_FROM_NAME=DevisVocal

# ─── App ────────────────────────────────────────────────────
APP_URL=https://app.devisvocal.ch
PORT=3001
# Token admin pour les endpoints protégés (/setup-webhook, /api/devis/:id/redeliver).
ADMIN_API_TOKEN=change_me_random_string
# Note : JWT_SECRET n'est plus utilisé (les tokens devis sont des UUID stockés en DB).

# ─── Next.js (web) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Espace client SaaS (Phase A) — auth Supabase côté navigateur.
# URL du projet Supabase + clé "anon" publique (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
